dist/

# Android build artifacts (muy pesados, se regeneran con Android Studio)
android/app/build/
android/.gradle/
android/build/
android/local.properties

# APKs — subirlos vía GitHub Releases, no al repo
*.apk
*.aab

# Keystore & signing secrets (¡nunca commitear!)
*.keystore
*.jks
*.p12
release.properties

